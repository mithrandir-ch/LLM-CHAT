{
  "name": "llm-chat",
  "displayName": "LLM-CHAT",
  "description": "Ollama Chat in VS Code",
  "version": "3.0.0",
  "publisher": "local",
  "engines": { "vscode": "^1.85.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "llm-chat", "title": "LLM-CHAT", "icon": "icons/chat.svg" }
      ]
    },
    "views": {
      "llm-chat": [
        { "type": "webview", "id": "llmChatView", "name": "Chat" }
      ]
    }
  }
}
